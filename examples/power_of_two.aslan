int n = 16;
bool is_power = false;

if (n <= 0) {
    is_power = false;
} else {
    while (n > 1) {
        int half = n / 2;
        int rem = n - (half * 2);
        
        if (rem != 0) {
            is_power = false;
            n = 0;
        } else {
            n = half;
        }
    }
    
    if (n == 1) {
        is_power = true;
    }
}

print(is_power);
