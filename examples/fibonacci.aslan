// LeetCode 509: Fibonacci Number
int n = 10;
int a = 0;
int b = 1;
int i = 0;
int temp = 0;

if (n == 0) {
    print(a);
} else {
    if (n == 1) {
        print(b);
    } else {
        i = 2;
        while (i <= n) {
            temp = a + b;
            a = b;
            b = temp;
            i = i + 1;
        }
        print(b);
    }
}
